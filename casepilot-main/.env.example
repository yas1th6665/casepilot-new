# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
GOOGLE_GENAI_USE_VERTEXAI=1

# Backend
BACKEND_URL=http://localhost:8000
CASEPILOT_DEFAULT_USER_ID=dashboard-user
CASEPILOT_TIMEZONE=Asia/Kolkata
CASEPILOT_LOCAL_UPLOAD_DIR=.casepilot_uploads

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/chat
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_ID=your-messaging-id
VITE_FIREBASE_APP_ID=your-app-id

# Google Integrations
GOOGLE_WORKSPACE_USER=you@example.com
GOOGLE_CALENDAR_CREDENTIALS_PATH=./service-account.json
GOOGLE_TASKS_CREDENTIALS_PATH=./service-account.json
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/google-auth/callback
GCS_BUCKET_NAME=your-casepilot-bucket

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://your-backend-url/webhook/telegram

# eCourts
ECOURTS_API_KEY=your-ecourts-api-key
